# ============================================================
# Retoquei — Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local or any file containing real secrets.
# ============================================================

# ------------------------------------------------------------
# App
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ------------------------------------------------------------
# Supabase
# Get these from: https://supabase.com/dashboard/project/<id>/settings/api
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# ------------------------------------------------------------
# Database (Prisma / PostgreSQL)
# Local default uses the Supabase local dev stack (port 54322).
# In production, use a connection pooler URL (e.g. Supabase pooler).
# ------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# For Prisma in serverless environments (direct connection for migrations):
# DIRECT_URL=postgresql://postgres:postgres@localhost:54322/postgres

# ------------------------------------------------------------
# Redis
# Local: plain Redis. Production: use Upstash or a managed Redis.
# ------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# Upstash Redis (used by @upstash/ratelimit and @upstash/redis)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ------------------------------------------------------------
# WhatsApp (Meta Cloud API)
# Docs: https://developers.facebook.com/docs/whatsapp/cloud-api
# ------------------------------------------------------------
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_API_VERSION=v19.0

# Set to "true" to simulate WhatsApp sends without hitting Meta's API.
# Messages will be logged to stdout only.
WHATSAPP_MOCK_MODE=true

# ------------------------------------------------------------
# Email (Nodemailer)
# Use a transactional email provider (Resend, Postmark, SMTP, etc.)
# ------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@retoquei.com.br

# ------------------------------------------------------------
# Admin / Internal
# ------------------------------------------------------------
ADMIN_SECRET_KEY=

# ------------------------------------------------------------
# Feature Flags
# ------------------------------------------------------------
# Enable real WhatsApp sends (requires WHATSAPP_* vars to be set).
ENABLE_REAL_WHATSAPP=false

# Enable Trinks connector (requires Trinks API credentials).
ENABLE_TRINKS_CONNECTOR=false

# Trinks API (official integration — see README for contract details)
TRINKS_API_BASE_URL=
TRINKS_API_KEY=
TRINKS_ESTABLISHMENT_ID=

# ─── AI (Anthropic) ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Stripe Billing ───────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_SCALE=price_...
NEXT_PUBLIC_STRIPE_PRICE_STARTER=price_...
NEXT_PUBLIC_STRIPE_PRICE_GROWTH=price_...
NEXT_PUBLIC_STRIPE_PRICE_SCALE=price_...

# ─── WhatsApp via QR Code (Evolution API) ─────────────────────────────────────
EVOLUTION_API_URL=https://sua-evolution-api.com
EVOLUTION_API_KEY=sua-api-key-global

# ─── Monitoring & Observability ───────────────────────────────────────────────
# Error tracking and monitoring (optional)
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_APP_VERSION=

# Enable detailed monitoring in production
ENABLE_MONITORING=true
MONITORING_SAMPLE_RATE=0.1  # Sample 10% of requests in production

