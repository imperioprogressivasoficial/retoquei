# ============================================================
# Retoquei — .gitignore
# ============================================================

# ---------------------------------------------------------------
# Dependencies
# ---------------------------------------------------------------
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# ---------------------------------------------------------------
# Next.js
# ---------------------------------------------------------------
.next/
out/
build/
dist/

# ---------------------------------------------------------------
# TypeScript
# ---------------------------------------------------------------
*.tsbuildinfo
next-env.d.ts

# ---------------------------------------------------------------
# Environment & Secrets — NEVER commit these
# ---------------------------------------------------------------
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env*.local

# ---------------------------------------------------------------
# Prisma
# ---------------------------------------------------------------
prisma/generated/

# ---------------------------------------------------------------
# Logs
# ---------------------------------------------------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log
logs/

# ---------------------------------------------------------------
# OS / Editor
# ---------------------------------------------------------------
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
*.swp
*.swo
*~

# ---------------------------------------------------------------
# Testing
# ---------------------------------------------------------------
coverage/
.nyc_output/
test-results/
playwright-report/

# ---------------------------------------------------------------
# Misc
# ---------------------------------------------------------------
.vercel
.turbo
*.tgz
*.zip
tmp/
temp/
.cache/
